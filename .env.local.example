# trida — Environment variables template
# Zkopíruj jako .env.local a doplň skutečné hodnoty.
# .env.local je gitignored — NIKDY ho necommituj.
#
# Production hodnoty jsou v Vercel env vars (Settings → Environment Variables).

# ============================================================================
# Supabase (Day 3)
# ============================================================================
# Z Supabase dashboardu (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Anthropic (Day 3)
# ============================================================================
# Z console.anthropic.com → Workspace settings → API keys
# Dev key: monthly limit $50
# Prod key: monthly limit $200+
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Stripe (Day 4)
# ============================================================================
# Z stripe.com → Developers → API keys
# Test mode pro dev, live mode parkováno do Fáze 5+
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Resend (Day 4)
# ============================================================================
# Z resend.com → API keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# App config (later)
# ============================================================================
# URL aktuálního prostředí (dev = http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
