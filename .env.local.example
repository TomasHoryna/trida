# trida — Environment variables template
# Zkopíruj jako .env.local a doplň skutečné hodnoty.
# .env.local je gitignored — NIKDY ho necommituj.
#
# Production hodnoty jsou v Vercel env vars (Settings → Environment Variables).

# ============================================================================
# Supabase (Day 3)
# ============================================================================
# Z Supabase dashboardu (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=<your_supabase_project_url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# ============================================================================
# Anthropic (Day 3)
# ============================================================================
# Z console.anthropic.com -> Workspace settings -> API keys
# Dev key: monthly limit $50
# Prod key: monthly limit $200+
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# ============================================================================
# Stripe (Day 4)
# ============================================================================
# Z stripe.com -> Developers -> API keys
# Test mode pro dev, live mode parkovano do Faze 5+
STRIPE_SECRET_KEY=<your_stripe_secret_key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your_stripe_publishable_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_signing_secret>

# ============================================================================
# Resend (Day 4)
# ============================================================================
# Z resend.com -> API keys
RESEND_API_KEY=<your_resend_api_key>

# ============================================================================
# App config (later)
# ============================================================================
# URL aktualniho prostredi (dev = http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
